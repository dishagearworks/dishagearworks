{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "disha-gearworks",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "disha-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
