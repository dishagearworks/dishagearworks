# ── DISHA GEARWORKS — static hosting (Apache / Hostinger) ────────────────
# This REPLACES any previous .htaccess that proxied requests to a Node.js
# app (which caused 503 errors). This serves the static export directly.

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve real files/folders directly (Next export uses /page/index.html, which
# Apache resolves automatically). No proxying to any backend.
DirectoryIndex index.html

# Custom 404 page from the static export
ErrorDocument 404 /404.html

# Long cache for hashed, immutable Next.js assets
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Reasonable cache for images
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
