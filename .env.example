# ──────────────────────────────────────────────────────────────────────
#  Contact form email delivery (Resend)
#  Copy this file to ".env.local" for local dev. In production, add these
#  in Vercel → Project → Settings → Environment Variables.
#  NEVER commit real keys — .env*.local is gitignored.
# ──────────────────────────────────────────────────────────────────────

# Required. Resend API key — create one at https://resend.com (API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Inbox that receives enquiries. Defaults to info@dishagearworks.in.
# (CONTACT_TO_EMAIL is also accepted as an alias.)
CONTACT_EMAIL=info@dishagearworks.in

# Optional. The "From" address — must use a domain verified in Resend.
# (Before domain verification, Resend only allows "onboarding@resend.dev",
#  which delivers solely to the Resend account owner's email.)
CONTACT_FROM_EMAIL="DISHA GEARWORKS <website@dishagearworks.in>"

# ──────────────────────────────────────────────────────────────────────
#  Google Analytics 4 (optional). Leave empty to disable analytics entirely.
#  Get the Measurement ID (G-XXXXXXXXXX) from GA4 → Admin → Data streams.
#  This is a NEXT_PUBLIC_ var (exposed to the browser, as GA requires).
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
